{
    "name": "server-bugbot",
    "version": "1.0.0",
    "description": "BugBot server application",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "nodemon src/index.js",
        "dev:infra": "cd infra && docker-compose up -d",
        "dev:infra:down": "cd infra && docker-compose down",
        "dev:infra:logs": "cd infra && docker-compose logs -f",
        "sql:init": "node scripts/init-clickhouse.js",
        "kafka:create-topics": "node scripts/create-kafka-topics.js",
        "verify": "node scripts/verify-setup.js",
        "test": "node scripts/test-system.js",
        "test:manual": "echo \"See TEST_CHECKLIST.md for manual testing instructions\""
    },
    "keywords": [
        "bugbot",
        "server",
        "api"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@clickhouse/client": "^0.2.10",
        "axios": "^1.13.2",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "express": "^4.21.2",
        "express-rate-limit": "^8.2.1",
        "express-validator": "^7.2.1",
        "form-data": "^4.0.4",
        "helmet": "^7.2.0",
        "kafkajs": "^2.2.4",
        "minio": "^7.1.3",
        "mkdirp": "^3.0.1",
        "mongodb": "^6.3.0",
        "morgan": "^1.10.1",
        "mqtt": "^5.14.1",
        "multer": "^1.4.5-lts.1",
        "nodemailer": "^7.0.10",
        "pino": "^8.19.0",
        "pino-pretty": "^10.3.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "nodemon": "^3.1.10"
    }
}
